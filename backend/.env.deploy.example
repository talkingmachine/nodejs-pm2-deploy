# Пример параметров деплоя. Скопируйте в .env.deploy и подставьте свои значения.
# Сам .env.deploy в репозиторий не коммитится (см. .gitignore).

# Пользователь удалённого сервера
DEPLOY_USER=username
# Адрес сервера: IP или ssh-алиас из ~/.ssh/config
DEPLOY_HOST=your-server-host
# Путь до приложения на сервере (туда pm2 разворачивает релизы)
DEPLOY_PATH=/home/username/mesto-backend
